# API server (run: npm run dev:api or npm run dev:full)
PORT=3001
# Admin UI is open without login by default. Set to 1 to require password login again:
# SPOTRATES_ADMIN_AUTH=1
ADMIN_PASSWORD=change-me-to-a-strong-secret
SESSION_SECRET=another-long-random-string
# Optional: set to 1 only when the site is served over HTTPS
# COOKIE_SECURE=1

# If login says "misconfiguration" while ADMIN_PASSWORD is in .env, your shell may inject an empty
# ADMIN_PASSWORD — use `npm run dev:api`, or copy server/local-admin-password.example to
# server/local-admin-password.txt (one line: your password).

# Optional: public site on a different host (production). Leave unset for local dev proxy.
# VITE_RATES_API_URL=https://your-api.example.com

# Vercel serverless admin + published rates (Upstash Redis — Vercel → Storage → Create → Redis)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Legacy Vercel KV names (still supported):
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
