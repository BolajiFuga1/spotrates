{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "headers": [
    {
      "source": "/favicon.png",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400, must-revalidate" }]
    }
  ],
  "redirects": [
    { "source": "/admin", "destination": "/admin.html", "permanent": false },
    { "source": "/admin/", "destination": "/admin.html", "permanent": false }
  ],
  "rewrites": [
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/admin/", "destination": "/admin.html" },
    { "source": "/about", "destination": "/index.html" },
    { "source": "/services", "destination": "/index.html" },
    { "source": "/news", "destination": "/index.html" },
    { "source": "/converter", "destination": "/index.html" },
    { "source": "/disclosure", "destination": "/index.html" }
  ]
}
